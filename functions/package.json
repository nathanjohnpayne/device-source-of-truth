{
  "name": "dsot-functions",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:contracts && tsc",
    "build:contracts": "cd ../packages/contracts && npm install --ignore-scripts && npm run build && cd ../../functions && mkdir -p .contracts/dist && cp ../packages/contracts/package.json .contracts/ && cp -r ../packages/contracts/dist/* .contracts/dist/",
    "dev": "tsc --watch",
    "pretest": "npm run build:contracts",
    "test": "vitest run && node ../scripts/check-no-public-secrets.mjs --scope functions",
    "test:watch": "vitest"
  },
  "engines": {
    "node": "22"
  },
  "overrides": {
    "@tootallnate/once": "3.0.1",
    "http-proxy-agent": "8.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dst/contracts": "file:./.contracts",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.1.1",
    "papaparse": "^5.5.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/papaparse": "^5.3.15",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
