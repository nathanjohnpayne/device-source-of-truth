{
  "name": "device-source-of-truth",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:contracts && vite",
    "build": "npm run build:contracts && tsc -b && vite build",
    "build:contracts": "cd packages/contracts && npm run build",
    "lint": "eslint .",
    "ui:consistency:check": "node scripts/ui-consistency-check.mjs",
    "ui:consistency:baseline": "node scripts/ui-consistency-check.mjs --write-baseline",
    "preview": "vite preview",
    "pretest": "npm run build:contracts",
    "test": "vitest run && node scripts/check-no-public-secrets.mjs",
    "test:watch": "vitest",
    "test:all": "npm test && cd functions && npm test",
    "test:secrets": "node scripts/check-no-public-secrets.mjs",
    "deploy": "op-firebase-deploy",
    "deploy:hosting": "op-firebase-deploy --only hosting",
    "deploy:functions": "op-firebase-deploy --only functions"
  },
  "dependencies": {
    "@dst/contracts": "file:packages/contracts",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/papaparse": "^5.5.2",
    "firebase": "^12.12.1",
    "lucide-react": "^1.11.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "flatted": "3.4.2",
    "undici": "7.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  }
}
