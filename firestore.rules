rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAllowedUser() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email));
    }

    match /users/{email} {
      allow read: if isAuthenticated();
    }

    match /partners/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /partnerKeys/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /devices/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /deviceSpecs/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /deviceDeployments/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /telemetrySnapshots/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /hardwareTiers/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /deviceTierAssignments/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /auditLog/{docId} {
      allow read: if isAllowedUser();
    }

    match /alerts/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /uploadHistory/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /config/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /fieldOptions/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /partnerKeyImportBatches/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /intakeRequests/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /intakeRequestPartners/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /intakeImportHistory/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /partnerAliases/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /questionnaireIntakeJobs/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /questionnaireStagedDevices/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /questionnaireStagedFields/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /deviceQuestionnaireSources/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /notifications/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /questionnaireIntakePartners/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /questionnaireStagedDevicePartners/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }

    match /devicePartnerDeployments/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser();
    }
  }
}
